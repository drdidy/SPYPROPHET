# Copy to `.env` and fill in. Read by python-dotenv at startup.
# In production, set these as real environment variables (Docker, k8s, Render, Fly).
# `.streamlit/secrets.toml` is also supported and takes precedence when present.

# === Tastytrade OAuth (required for live options quotes) ===
TASTYTRADE_CLIENT_ID=
TASTYTRADE_CLIENT_SECRET=
TASTYTRADE_REFRESH_TOKEN=
TASTYTRADE_ENVIRONMENT=production

# === Optional: external data providers ===
UNUSUAL_WHALES_API_KEY=
ECONOMIC_CALENDAR_API_URL=
GEX_API_URL=
SOCIAL_SENTIMENT_API_URL=
TRADING_ECONOMICS_CREDENTIAL=

# === Optional: AI briefing ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# === Operational ===
# Override journal storage path (default: data/signal_journal.json)
JOURNAL_PATH=
# Enable in-app debug panels
SPYPROPHET_ADMIN_MODE=
# Override structure calibration slope per hour (default 0.20)
SPYPROPHET_SLOPE_PER_HOUR=

# === Observability ===
# When set, errors are reported to Sentry. Leave blank to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
